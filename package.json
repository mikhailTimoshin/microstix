{
  "name": "microstix",
  "version": "1.6.0",
  "description": "TypeScript библиотека для микрофронтендов с минимальной конфигурацией",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.mjs",
      "require": "./dist/vite-plugin.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "postversion": "git push --set-upstream origin master && git push --tags",
    "pub:patch": "npm version patch && npm publish --access public",
    "pub:minor": "npm version minor && npm publish --access public",
    "pub:major": "npm version major && npm publish --access public"
  },
  "keywords": [
    "microfrontend",
    "typescript",
    "vite",
    "plugin",
    "build-tool"
  ],
  "author": "Leto <m.timoshin88@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikhailTimoshin/microstix.git"
  },
  "bugs": {
    "url": "https://github.com/mikhailTimoshin/microstix/issues"
  },
  "homepage": "https://github.com/mikhailTimoshin/microstix/README.md",
  "peerDependencies": {
    "vite": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vite": "^5.4.21"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
